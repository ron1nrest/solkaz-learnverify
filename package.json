{
  "name": "@solkaz/learnverify",
  "version": "0.1.0",
  "description": "Open-source Devnet skill verification CLI for Solana education in Kazakhstan",
  "type": "module",
  "license": "MIT",
  "bin": {
    "learnverify": "./dist/cli.js"
  },
  "files": [
    "dist",
    "challenges/examples",
    "schema"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "vitest run tests/e2e",
    "test:watch": "vitest",
    "test:ci": "npm run lint && npm run format && npm run build && npx tsx scripts/security-check.ts && npm run validate-challenges && npm run test",
    "security-check": "tsx scripts/security-check.ts",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\" \"scripts/**/*.ts\"",
    "format": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\" \"scripts/**/*.ts\"",
    "format:write": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\" \"scripts/**/*.ts\"",
    "validate-challenges": "tsx scripts/validate-challenges.ts",
    "doctor": "node dist/cli.js doctor"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@solana/spl-token": "^0.4.13",
    "@solana/web3.js": "^1.98.4",
    "commander": "^13.1.0",
    "picocolors": "^1.1.1",
    "yaml": "^2.7.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@types/node": "^22.13.10",
    "eslint": "^9.22.0",
    "prettier": "^3.5.3",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.26.1",
    "vitest": "^3.0.8"
  }
}
